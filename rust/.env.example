# Database
DATABASE_URL=postgres://invoiceuser:invoicepass@db:5432/invoiceapp

# JWT — use a long random string, e.g. `openssl rand -hex 64`
JWT_SECRET=change_me_to_a_very_long_random_secret_string
JWT_EXPIRY_SECS=900          # 15 minutes
REFRESH_SECRET=another_long_random_secret
REFRESH_EXPIRY_SECS=604800   # 7 days

# SMTP (optional — invoice sending)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=smtp_password
SMTP_FROM=noreply@example.com

# Chromium path inside the Docker container
CHROMIUM_PATH=/usr/bin/chromium

# File uploads storage directory
UPLOAD_DIR=/app/uploads

# Port the Axum backend listens on
PORT=4000

# Frontend base URL (used for CORS)
FRONTEND_URL=http://localhost:3000
